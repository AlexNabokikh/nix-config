#!/usr/bin/env python3
"""recursively pull all git repos under a fixed root."""

import os
import shutil
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

ROOT = Path.home() / "Documents" / "repositories"


def find_repos(root: Path):
    for dirpath, dirnames, _ in os.walk(root, followlinks=False):
        p = Path(dirpath)
        if (p / ".git").exists():
            yield p
            dirnames[:] = []  # stop descending into the repo
            continue
        dirnames.sort()


def current_branch(repo: Path) -> str:
    r = subprocess.run(
        ["git", "-C", str(repo), "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True,
        text=True,
    )
    return r.stdout.strip() or "?"


def pull(repo: Path):
    r = subprocess.run(
        ["git", "-C", str(repo), "pull", "--ff-only"],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
    )
    return r.returncode, r.stdout


def pull_with_repo(repo: Path):
    rc, out = pull(repo)
    return repo, rc, out


def short_msg(out: str) -> str:
    for line in out.splitlines():
        line = line.strip()
        if line:
            return line if len(line) <= 200 else line[:197] + "..."
    return ""


def main() -> None:
    if not ROOT.is_dir():
        print(f"gpa: root not found: {ROOT}", file=sys.stderr)
        sys.exit(1)
    if shutil.which("git") is None:
        print("gpa: git not found on PATH", file=sys.stderr)
        sys.exit(1)

    repos = sorted(find_repos(ROOT))
    if not repos:
        print(f"gpa: no git repos found under {ROOT}")
        return

    rel_width = max(len(str(r.relative_to(ROOT))) for r in repos)

    with ThreadPoolExecutor() as ex:
        branches = list(ex.map(current_branch, repos))

    with ThreadPoolExecutor() as ex:
        pull_results = list(ex.map(pull_with_repo, repos))

    rows = []
    for repo, branch, result in zip(repos, branches, pull_results):
        _, rc, out = result
        status = "OK  " if rc == 0 else "FAIL"
        rows.append((status, repo, branch, short_msg(out)))

    branch_width = max(len(b) for _, _, b, _ in rows)

    for status, repo, branch, msg in rows:
        rel = str(repo.relative_to(ROOT))
        print(f"{status}  {rel:<{rel_width}}  {branch:<{branch_width}}  {msg}")

    failed = sum(1 for s, *_ in rows if s.strip() == "FAIL")
    ok = len(rows) - failed
    print(f"---\n{len(rows)} repos: {ok} ok, {failed} failed")
    sys.exit(0 if failed == 0 else 1)


if __name__ == "__main__":
    main()

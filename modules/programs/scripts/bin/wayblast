#!/usr/bin/env bash

set -euo pipefail

exec 200>"${XDG_RUNTIME_DIR:-/tmp}/wayblast.lock"
flock -n 200 || exit 0

freeze_pid=""

cleanup() {
  if [[ -n "$freeze_pid" ]]; then
    kill "$freeze_pid" 2>/dev/null || true
    wait "$freeze_pid" 2>/dev/null || true
  fi
}

freeze() {
  wayfreeze --hide-cursor --enable-keyboard >/dev/null 2>&1 &
  freeze_pid=$!
  sleep 0.2
}

trap cleanup EXIT

case "${1:-}" in
area)
  freeze
  grim -g "$(slurp)" -
  ;;
fullscreen)
  freeze
  grim -
  ;;
*)
  printf 'Usage: %s {area|fullscreen}\n' "$(basename "$0")" >&2
  exit 2
  ;;
esac

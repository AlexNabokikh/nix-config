#!/usr/bin/env bash

set -euo pipefail

RECORDINGS_DIR="$HOME/Videos"

mkdir -p "$RECORDINGS_DIR"

if pgrep -f gpu-screen-recorder >/dev/null; then
  killall -s SIGINT gpu-screen-recorder
  sleep 1
  LATEST=$(find "$RECORDINGS_DIR" -maxdepth 1 -name "recording_*.mp4" -printf '%T@ %p\n' 2>/dev/null |
    sort -rn | head -1 | cut -d' ' -f2-)
  if [ -n "$LATEST" ]; then
    (
      ACTION=$(notify-send -u normal "Screen Recording" "Recording saved" \
        --action="default=Open Recording")
      [ "$ACTION" = "default" ] && xdg-open "$LATEST"
    ) &
  else
    notify-send -u normal "Screen Recording" "Recording stopped"
  fi
else
  gpu-screen-recorder \
    -w portal \
    -f 60 \
    -k hevc \
    -q very_high \
    -cr limited \
    -cursor yes \
    -o "$RECORDINGS_DIR/recording_$(date +%Y%m%d_%H%M%S).mp4" &
fi

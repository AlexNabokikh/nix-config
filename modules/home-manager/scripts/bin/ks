#!/usr/bin/env python3
"""ks: kubectx -> AWS account -> AWS profile -> `assume` shell."""

import configparser
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

REQUIRED_TOOLS = ("kubectx", "kubectl", "assume")
AWS_CONFIG = Path.home() / ".aws" / "config"


def check_tools() -> None:
    missing = [t for t in REQUIRED_TOOLS if shutil.which(t) is None]
    if missing:
        print(
            f"ks: missing required tool(s) on PATH: {', '.join(missing)}",
            file=sys.stderr,
        )
        sys.exit(1)


def run_kubectx() -> None:
    rc = subprocess.run(["kubectx"]).returncode
    if rc != 0:
        print("ks: kubectx cancelled or failed", file=sys.stderr)
        sys.exit(130)


def current_context() -> str:
    result = subprocess.run(
        ["kubectl", "config", "current-context"],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


def account_from_context(ctx: str) -> str:
    m = re.match(r"^(\d{12})\.", ctx)
    if not m:
        print(
            f"ks: cannot extract AWS account ID from context: {ctx!r}",
            file=sys.stderr,
        )
        sys.exit(2)
    return m.group(1)


def profile_for_account(account_id: str) -> str:
    if not AWS_CONFIG.is_file():
        print(f"ks: {AWS_CONFIG} not found", file=sys.stderr)
        sys.exit(3)

    cp = configparser.ConfigParser()
    cp.read(AWS_CONFIG)

    for section in cp.sections():
        if not section.startswith("profile "):
            continue
        name = section[len("profile "):].strip()
        if cp[section].get("granted_sso_account_id", "").strip() == account_id:
            return name

    # Fallback: match by name prefix.
    for section in cp.sections():
        if not section.startswith("profile "):
            continue
        name = section[len("profile "):].strip()
        if name.startswith(f"{account_id}."):
            return name

    print(
        f"ks: no AWS profile found for account {account_id} in {AWS_CONFIG}",
        file=sys.stderr,
    )
    sys.exit(3)


def exec_assume(profile: str) -> None:
    shell = os.environ.get("SHELL", "/bin/sh")
    env = {**os.environ, "GRANTED_ALIAS_CONFIGURED": "true"}
    os.execvpe(
        "assume",
        ["assume", "--exec", shell, profile],
        env,
    )


def main() -> None:
    check_tools()
    run_kubectx()
    ctx = current_context()
    account = account_from_context(ctx)
    profile = profile_for_account(account)
    exec_assume(profile)


if __name__ == "__main__":
    main()

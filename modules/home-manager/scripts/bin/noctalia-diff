#!/usr/bin/env bash
# Diff noctalia-shell upstream default settings to spot new/changed keys
# after upgrades, or to verify your local settings against pinned defaults.
#
# Usage:
#   noctalia-diff               # pinned vs. latest upstream defaults (default)
#   noctalia-diff upstream      # same as above
#   noctalia-diff local         # pinned defaults vs. ~/.config/noctalia/settings.json
#   noctalia-diff widgets       # pinned vs. latest widget defaults

set -euo pipefail

mode="${1:-upstream}"

if ! command -v jq >/dev/null || ! command -v json-diff >/dev/null; then
	exec nix shell nixpkgs#jq nixpkgs#json-diff -c "$0" "$@"
fi

flake_dir="$(git -C "$(dirname "$(readlink -f "$0")")" rev-parse --show-toplevel 2>/dev/null || pwd)"

pinned_ref=$(nix flake metadata --json "$flake_dir" \
	| jq -r '.locks.nodes.noctalia.locked | "github:\(.owner)/\(.repo)/\(.rev)"')
pinned_path=$(nix flake prefetch --json "$pinned_ref" | jq -r .storePath)

case "$mode" in
upstream)
	latest_path=$(nix flake prefetch --json github:noctalia-dev/noctalia-shell | jq -r .storePath)
	echo "Diffing pinned ($pinned_ref) vs. latest noctalia-shell defaults..."
	json-diff \
		<(jq -S . "$pinned_path/Assets/settings-default.json") \
		<(jq -S . "$latest_path/Assets/settings-default.json")
	;;
widgets)
	latest_path=$(nix flake prefetch --json github:noctalia-dev/noctalia-shell | jq -r .storePath)
	echo "Diffing pinned ($pinned_ref) vs. latest noctalia-shell widget defaults..."
	json-diff \
		<(jq -S . "$pinned_path/Assets/settings-widgets-default.json") \
		<(jq -S . "$latest_path/Assets/settings-widgets-default.json")
	;;
local)
	echo "Diffing pinned ($pinned_ref) defaults vs. local settings.json..."
	json-diff \
		<(jq -S . "$pinned_path/Assets/settings-default.json") \
		<(jq -S . "$HOME/.config/noctalia/settings.json")
	;;
*)
	echo "Unknown mode: $mode (expected: upstream | widgets | local)" >&2
	exit 1
	;;
esac

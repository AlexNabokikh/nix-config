# Optional when proxmox.auto.tfvars already contains the token secret.
#
# If you set this here, it overrides proxmox.auto.tfvars because this file loads
# later alphabetically. Use the Proxmox token secret UUID, not the token ID.
# proxmox_token_secret = "00000000-0000-0000-0000-000000000000"

# Optional destructive bootstrap. Set true only when you want Terraform apply to
# install NixOS from the custom SSH-enabled installer ISO via nixos-anywhere.
# management_vm_nixos_anywhere_enabled = true
# management_vm_nixos_anywhere_target = "root@10.0.40.100"
# management_vm_nixos_anywhere_identity_file = "~/.ssh/id_macbook_fs"

# This repo prefers Terraform variables from direnv:
#
# export TF_VAR_proxmox_token_secret="00000000-0000-0000-0000-000000000000"
# export TF_VAR_cloudflare_enabled=true
# export TF_VAR_cloudflare_api_token="replace-me"
# export TF_VAR_cloudflare_account_id="replace-me"
# export TF_VAR_cloudflare_zone_id="replace-me"
# export TF_VAR_cloudflare_zone_name="krapulax.dev"
# export TF_VAR_cloudflare_tunnel_id="bd117d0e-5b13-44b9-b4ae-4136918b5ce5"
#
# To let Terraform create the tunnel instead of using an existing ID:
# export TF_VAR_cloudflare_create_tunnel=true
# export TF_VAR_cloudflare_tunnel_name="trinity"
# export TF_VAR_cloudflare_manage_tunnel_config=false
#
# Optional Cloudflare Access protection:
# export TF_VAR_cloudflare_access_enabled=true
# export TF_VAR_cloudflare_access_allowed_emails='["you@example.com"]'

# Optional when proxmox.auto.tfvars already contains the token secret.
#
# If you set this here, it overrides proxmox.auto.tfvars because this file loads
# later alphabetically. Use the Proxmox token secret UUID, not the token ID.
# proxmox_token_secret = "00000000-0000-0000-0000-000000000000"

# VM deployment no longer runs nixos-anywhere from Terraform. `just vm-deploy`
# creates cloud-init VMs and then applies NixOS via `nixos-rebuild switch`.

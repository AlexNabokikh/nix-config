# Terraform secrets now live in Doppler. Keep this file as a shape reference
# only; do not copy it to secrets.auto.tfvars for normal repo operations.
#
# The `just tf` wrapper uses `doppler run --name-transformer tf-var --` to
# expose these uppercase Doppler keys as Terraform's lowercase TF_VAR_* names:
#
# PROXMOX_TOKEN_SECRET="00000000-0000-0000-0000-000000000000"
# CLOUDFLARE_ENABLED=true
# CLOUDFLARE_API_TOKEN="replace-me"
# CLOUDFLARE_ACCOUNT_ID="replace-me"
# CLOUDFLARE_ZONE_ID="replace-me"
# CLOUDFLARE_ZONE_NAME="krapulax.dev"
# CLOUDFLARE_CREATE_TUNNEL=true
# CLOUDFLARE_TUNNEL_NAME="trinity"
# CLOUDFLARE_MANAGE_TUNNEL_CONFIG=false
# CLOUDFLARE_ACCESS_ENABLED=false

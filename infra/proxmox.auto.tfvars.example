# Proxmox API endpoint URL.
proxmox_endpoint = "https://10.0.40.11:8006"

# Set true when using the self-signed Proxmox certificate.
proxmox_insecure = true

# Default Proxmox node name used by the cluster config.
proxmox_node = "pve-1"

# Proxmox API token ID, for example: terraform@pve!terraform.
proxmox_token_id = "replace-me"

# Proxmox API token secret UUID.
proxmox_token_secret = "00000000-0000-0000-0000-000000000000"

# Optional: override VM IPs, sizes, nodes, or DNS from management_variables.tf.
# vms = {
#   trinity = {
#     target_node   = "pve-2"
#     vm_id         = 4061
#     ipv4_address  = "10.0.40.61"
#     prefix_length = 24
#     gateway       = "10.0.40.1"
#     dns           = ["1.1.1.1", "1.0.0.1"]
#   }
# }

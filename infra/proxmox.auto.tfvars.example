# Proxmox connection values now live in Doppler for normal repo operations.
# Keep this file as a shape reference only; do not copy it to
# proxmox.auto.tfvars unless you intentionally want a local Terraform override.
#
# The `just tf` wrapper uses `doppler run --name-transformer tf-var --` to
# expose these uppercase Doppler keys as Terraform's lowercase TF_VAR_* names:
#
# PROXMOX_ENDPOINT="https://10.0.40.11:8006"
# PROXMOX_INSECURE=true
# PROXMOX_NODE="pve-1"
# PROXMOX_TOKEN_ID="replace-me"
# PROXMOX_TOKEN_SECRET="00000000-0000-0000-0000-000000000000"

# Optional: override VM IPs, sizes, nodes, or DNS from management_variables.tf.
# vms = {
#   trinity = {
#     target_node   = "pve-2"
#     vm_id         = 4061
#     ipv4_address  = "10.0.40.61"
#     prefix_length = 24
#     gateway       = "10.0.40.1"
#     dns           = ["1.1.1.1", "1.0.0.1"]
#   }
# }
